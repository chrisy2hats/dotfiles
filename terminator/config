[global_config]
  geometry_hinting = True
  window_state = maximise
  tab_position = hidden
  inactive_color_offset = 0.7564102564102564
  enabled_plugins = LaunchpadBugURLHandler, LaunchpadCodeURLHandler, APTURLHandler, TerminatorFileManager
  ask_before_closing = never
[keybindings]
  go_up = <Alt>k
  go_down = <Alt>j
  go_left = <Alt>h
  go_right = <Alt>l
  move_tab_right = None
  move_tab_left = None
  next_tab = None
  prev_tab = <Primary><Shift>q
  broadcast_off = <Shift><Alt>a
  layout_launcher = <Super>l
[profiles]
  [[default]]
    icon_bell = False
    background_darkness = 0.43
    font = Ubuntu Mono 13
    show_titlebar = False
    scrollbar_position = hidden
    scrollback_infinite = True
    custom_command = configureTerminator
    copy_on_selection = True
[layouts]
  [[default]]
    [[[child1]]]
      directory = ""
      parent = window0
      profile = darkTerminator
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
